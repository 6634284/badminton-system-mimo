{
  "name": "badminton-server",
  "private": true,
  "version": "0.1.0",
  "description": "Badminton club SaaS platform - NestJS monorepo",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev:client-api": "nest start client-api --watch",
    "dev:admin-api": "nest start admin-api --watch",
    "dev:open-api": "nest start open-api --watch",
    "dev:worker": "nest start worker --watch",
    "dev:scheduler": "nest start scheduler --watch",
    "dev:ws-gateway": "nest start ws-gateway --watch",
    "build": "nest build",
    "build:client-api": "nest build client-api",
    "build:admin-api": "nest build admin-api",
    "build:open-api": "nest build open-api",
    "build:worker": "nest build worker",
    "build:scheduler": "nest build scheduler",
    "build:ws-gateway": "nest build ws-gateway",
    "start:prod:client-api": "node dist/apps/client-api/main",
    "start:prod:admin-api": "node dist/apps/admin-api/main",
    "start:prod:open-api": "node dist/apps/open-api/main",
    "start:prod:worker": "node dist/apps/worker/main",
    "start:prod:scheduler": "node dist/apps/scheduler/main",
    "start:prod:ws-gateway": "node dist/apps/ws-gateway/main",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio",
    "gen:admin-sdk": "ts-node scripts/gen-sdk.ts admin",
    "gen:client-sdk": "ts-node scripts/gen-sdk.ts client",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./apps/*/test/jest-e2e.json"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.24",
    "@nestjs/schedule": "^5.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/websockets": "^11.1.24",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "prisma": "^6.0.0",
    "swagger-typescript-api": "^13.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.0"
  }
}
