{
  "name": "badminton-client-taro",
  "version": "0.1.0",
  "private": true,
  "description": "Badminton club client - Taro cross-platform",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "build:h5": "taro build --type h5",
    "build:rn": "taro build --type rn",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "dependencies": {
    "@tanstack/react-query": "^5.60.0",
    "@tarojs/components": "4.x",
    "@tarojs/helper": "4.x",
    "@tarojs/plugin-framework-react": "4.x",
    "@tarojs/plugin-platform-h5": "4.x",
    "@tarojs/plugin-platform-weapp": "4.x",
    "@tarojs/react": "4.x",
    "@tarojs/runtime": "4.x",
    "@tarojs/shared": "4.x",
    "@tarojs/taro": "4.x",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.8.0",
    "@babel/preset-react": "^7.29.7",
    "@babel/runtime": "^7.7.7",
    "@tarojs/cli": "4.x",
    "@tarojs/webpack5-runner": "4.x",
    "@types/react": "^18.3.0",
    "babel-preset-taro": "4.x",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "webpack": "5.91.0"
  }
}
